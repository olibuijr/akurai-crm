{
  "routes": [
    { "path": "/", "template": "index.html", "layout": "none" },
    { "path": "/dashboard", "template": "dashboard.html", "layout": "default" },
    { "path": "/people", "template": "people.html", "layout": "default" },
    { "path": "/person/{id}", "template": "person-detail.html", "layout": "default" },
    { "path": "/companies", "template": "companies.html", "layout": "default" },
    { "path": "/company/{id}", "template": "company-detail.html", "layout": "default" },
    { "path": "/opportunities", "template": "opportunities.html", "layout": "default" },
    { "path": "/opportunity/{id}", "template": "opportunity-detail.html", "layout": "default" },
    { "path": "/tasks", "template": "tasks.html", "layout": "default" },
    { "path": "/notes", "template": "notes.html", "layout": "default" },
    { "path": "/settings", "template": "settings.html", "layout": "default" },
    { "path": "/api/_meta", "handler": "meta", "method": "GET" },
    { "path": "/api/people", "handler": "list:people", "method": "GET" },
    { "path": "/api/people/{id}", "handler": "get:people", "method": "GET" },
    { "path": "/api/people", "handler": "create:people", "method": "POST" },
    { "path": "/api/people/{id}", "handler": "update:people", "method": "PUT" },
    { "path": "/api/people/{id}", "handler": "delete:people", "method": "DELETE" },
    { "path": "/api/companies", "handler": "list:companies", "method": "GET" },
    { "path": "/api/companies/{id}", "handler": "get:companies", "method": "GET" },
    { "path": "/api/companies", "handler": "create:companies", "method": "POST" },
    { "path": "/api/companies/{id}", "handler": "update:companies", "method": "PUT" },
    { "path": "/api/companies/{id}", "handler": "delete:companies", "method": "DELETE" },
    { "path": "/api/opportunities", "handler": "list:opportunities", "method": "GET" },
    { "path": "/api/opportunities/{id}", "handler": "get:opportunities", "method": "GET" },
    { "path": "/api/opportunities", "handler": "create:opportunities", "method": "POST" },
    { "path": "/api/opportunities/{id}", "handler": "update:opportunities", "method": "PUT" },
    { "path": "/api/opportunities/{id}", "handler": "delete:opportunities", "method": "DELETE" },
    { "path": "/api/tasks", "handler": "list:tasks", "method": "GET" },
    { "path": "/api/tasks/{id}", "handler": "get:tasks", "method": "GET" },
    { "path": "/api/tasks", "handler": "create:tasks", "method": "POST" },
    { "path": "/api/tasks/{id}", "handler": "update:tasks", "method": "PUT" },
    { "path": "/api/tasks/{id}", "handler": "delete:tasks", "method": "DELETE" },
    { "path": "/api/notes", "handler": "list:notes", "method": "GET" },
    { "path": "/api/notes/{id}", "handler": "get:notes", "method": "GET" },
    { "path": "/api/notes", "handler": "create:notes", "method": "POST" },
    { "path": "/api/notes/{id}", "handler": "update:notes", "method": "PUT" },
    { "path": "/api/notes/{id}", "handler": "delete:notes", "method": "DELETE" },
    { "path": "/api/search", "handler": "search", "method": "GET" },
    { "path": "/api/timeline", "handler": "timeline", "method": "GET" }
  ]
}
